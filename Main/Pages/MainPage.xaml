<ContentPage
    x:Class="Main.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Main.ViewModels"
    Title="Soldes mensuels">

    <Grid>
        <Border Margin="10" Padding="10" BackgroundColor="#F5F5F5" StrokeShape="RoundRectangle 12" StrokeThickness="0" >
            <Border.Shadow>
                <Shadow 
                    Brush="#40000000"
                    Offset="0,2"
                    Radius="6"
                    Opacity="0.25" />
            </Border.Shadow>
            <CollectionView ItemsSource="{Binding Accounts}" SelectionMode="Single">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:BankAccountViewModel">

                        <Grid Padding="0,5">
                            <Border Margin="0,6" Padding="3" BackgroundColor="#E8F2FF" StrokeShape="RoundRectangle 24" >
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:BankAccountViewModel}}, Path=SelectAccountCommand}"
                                        CommandParameter="{Binding}" />     
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="#20000000"
                                        Offset="0,3"
                                        Radius="8"
                                        Opacity="0.25" />
                                </Border.Shadow>


                                <Grid Padding="12"
                                    ColumnDefinitions="*, Auto"
                                    RowDefinitions="Auto, Auto">
                                    <Label Grid.Column="0" Text="{Binding Label}" FontSize="18" FontAttributes="Bold" />
                                    <Label Grid.Column="0" Grid.Row="1" Text="{Binding AccountNo}" FontSize="14" />
                                    <Label Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                           Text="{Binding Balance, StringFormat='{0:N2} €'}"
                                           FontSize="14" 
                                           TextColor="{Binding BalanceColor}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Border>

        <!-- Bouton flottant -->
        <ImageButton
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="20"
            Source="plus.png"
            HeightRequest="56"
            WidthRequest="56"
            Visual="Material"
            BackgroundColor="Transparent"
            Command="{Binding AddCommand}" />
    </Grid>
</ContentPage>
