<ContentPage
    x:Class="Main.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Main.ViewModels"
    Title="Soldes mensuels">

    <Grid>
        <Border Margin="10" Padding="10" BackgroundColor="#F5F5F5" StrokeShape="RoundRectangle 12" StrokeThickness="0">
            <CollectionView ItemsSource="{Binding Accounts}" >
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,6" Padding="3" BackgroundColor="AliceBlue" StrokeShape="RoundRectangle 24">
                            <Grid Padding="12"  BackgroundColor="AliceBlue" ColumnDefinitions="*, Auto"
                                  RowDefinitions="Auto, Auto">
 
                                <Label Grid.Column="0" Text="{Binding Label}" FontSize="18" FontAttributes="Bold" />
                                <Label Grid.Column="0" Grid.Row="1" Text="{Binding AccountNo}" FontSize="14" />
                                <Label Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"  
                                    Text="{Binding Balance, StringFormat='{0:N2} €'}" FontSize="14" TextColor="DarkGreen"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                            </Grid>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- Bouton flottant -->
        <ImageButton
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="20"
            Source="plus.png"
            HeightRequest="56"
            WidthRequest="56"
            Visual="Material"
            BackgroundColor="Transparent"
            Command="{Binding AddCommand}" />
    </Grid>
</ContentPage>
