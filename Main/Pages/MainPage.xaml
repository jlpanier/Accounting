<ContentPage
    x:Class="Main.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Main.ViewModels"
    xmlns:templates="clr-namespace:Main.Templates"
    xmlns:selectors="clr-namespace:Main.Templates"
    xmlns:customs="clr-namespace:Main.Customs"
    Title="Sélection du mois">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>

        <!-- ===================== -->
        <!--   TEMPLATES PAR TYPE  -->
        <!-- ===================== -->

        <DataTemplate x:Key="BankTemplate">
            <templates:BankAccountTemplate />
        </DataTemplate>

        <DataTemplate x:Key="SavingTemplate">
            <templates:SavingAccountTemplate />
        </DataTemplate>

        <DataTemplate x:Key="PeeTemplate">
            <templates:PeeTemplate />
        </DataTemplate>

        <DataTemplate x:Key="ScpiTemplate">
            <templates:ScpiTemplate />
        </DataTemplate>

        <DataTemplate x:Key="OverviewTemplate">
            <templates:OverviewTemplate />
        </DataTemplate>

        <!-- ===================== -->
        <!--   TEMPLATE SELECTOR   -->
        <!-- ===================== -->

        <selectors:AccountTemplateSelector 
            x:Key="AccountSelector"
            BankTemplate="{StaticResource BankTemplate}"
            PeeTemplate="{StaticResource PeeTemplate}"
            ScpiTemplate="{StaticResource ScpiTemplate}"
            OverviewTemplate="{StaticResource OverviewTemplate}"
            SavingTemplate="{StaticResource SavingTemplate}" />

    </ContentPage.Resources>

    <ScrollView>
        <Grid BackgroundColor="White">

            <!-- Zone de swipe -->
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left" Command="{Binding NextMonthCommand}" />
                <SwipeGestureRecognizer Direction="Right" Command="{Binding PreviousMonthCommand}" />
            </Grid.GestureRecognizers>

            <!-- Carte contenant la liste -->
            <Border Margin="20"
                Padding="20"
                BackgroundColor="#FAFAFA"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="0">

                <Border.Shadow>
                    <Shadow Brush="#40000000"
                        Offset="0,4"
                        Radius="10"
                        Opacity="0.25" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="24">

                    <!-- Mois affiché -->
                    <Label x:Name="MonthLabel"
                       Text="{Binding MonthLabel}"
                       FontSize="34"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#333"
                       Opacity="1" />

                    <!-- Liste des comptes -->
                    <CollectionView ItemsSource="{Binding Accounts}"
                                ItemTemplate="{StaticResource AccountSelector}"
                                SelectionMode="None"
                                Margin="0,10,0,0"
                                VerticalOptions="Fill"
                                />

                </VerticalStackLayout>

            </Border>
            <!-- FAB pour ajouter un compte -->
            <ImageButton
                HorizontalOptions="End"
                Margin="20"
                Source="plus.png"
                HeightRequest="56"
                WidthRequest="56"
                Visual="Material"
                BackgroundColor="Transparent"
                Command="{Binding AddCommand}" />
        </Grid>

    </ScrollView>
</ContentPage>
