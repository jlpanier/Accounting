<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Main.ViewModels"
    xmlns:converter="clr-namespace:Main.Converter"
    x:Class="Main.Pages.SelectTypeAccountPage"
    Title="Type de compte">

    <VerticalStackLayout Padding="20" Spacing="20">



        <Label Text="Sélectionnez un type de compte"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <CollectionView
            ItemsSource="{Binding AccountTypes}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedAccountType, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="40,*">

                        <!-- RadioButton lié à l'item -->
                        <RadioButton
                            Grid.Column="0"
                            GroupName="AccountTypeGroup"
                            Value="{Binding .}"
                            IsChecked="{Binding BindingContext.SelectedAccountType, 
                                Source={RelativeSource AncestorType={x:Type ContentPage}},
                                Mode=TwoWay,
                                Converter={StaticResource EqualsConverter}, 
                                ConverterParameter={Binding .}}"
                            />

                        <!-- Texte du type de compte -->
                        <Label Grid.Column="1"
                               Text="{Binding .}"
                               VerticalOptions="Center"
                               FontSize="18"
                               TextColor="{Binding IsSelected, 
                                           Converter={StaticResource BoolToColorConverter},
                                           ConverterParameter='OnPrimaryColor,PrimaryColor'}" 
                        />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="Valider"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource PrimaryColor}"
                TextColor="{StaticResource OnPrimaryColor}"
                CornerRadius="12"
                HeightRequest="48" />

    </VerticalStackLayout>

</ContentPage>
