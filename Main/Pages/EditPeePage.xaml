<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Class="Main.Pages.EditPeePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Main.ViewModels"
    xmlns:converter="clr-namespace:Main.Converter"
    Title="Saisir les soldes">

    <ContentPage.BindingContext>
        <viewmodel:EditPeeViewModel />
    </ContentPage.BindingContext>
    <ContentPage.Resources>
        <ResourceDictionary>
            <converter:DoubleConverter x:Key="DoubleConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="22">

            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="#EEF8E8"
                    Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Date "
                           FontSize="18"
                           FontAttributes="Bold" />

                    <DatePicker Date="{Binding EffectiveOn, Mode=TwoWay}"
                                Format="dd/MM/yyyy" />
                </VerticalStackLayout>
            </Border>
            
            <!-- Carte Disponible -->
            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="#E8F2FF"
                    Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Solde disponible"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Entry 
                       Placeholder="Disponible"
                       Text="{Binding Disponible, Mode=TwoWay, Converter={StaticResource DoubleConverter}}"
                       Keyboard="Numeric"
                       VerticalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Carte Retraite -->
            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="#FFF4E8"
                    Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Solde retraite"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Entry Placeholder="0,00 €"
                           Keyboard="Numeric"
                           Text="{Binding Retirement, Mode=TwoWay}" />
                </VerticalStackLayout>
            </Border>

            <!-- Carte Bloqué -->
            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="#FFE8E8"
                    Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Solde bloqué"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Entry Placeholder="0,00 €"
                           Keyboard="Numeric"
                           Text="{Binding Blocked, Mode=TwoWay}" />
                </VerticalStackLayout>
            </Border>

            <!-- Bouton Enregistrer -->
            <Button Text="Enregistrer"
                    HeightRequest="52"
                    CornerRadius="14"
                    BackgroundColor="#4A90E2"
                    TextColor="White"
                    Command="{Binding SaveBalancesCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
