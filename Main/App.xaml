<?xml version = "1.0" encoding = "UTF-8" ?>
<Application 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converter="clr-namespace:Main.Converter"
    x:Class="Main.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="M3Primary">#6750A4</Color>
            <Color x:Key="M3OnPrimary">#FFFFFF</Color>
            <Color x:Key="M3Surface">#FFFFFF</Color>
            <Color x:Key="M3SurfaceVariant">#E7E0EC</Color>

            <!-- Style Material 3 avec animation -->
            <Style x:Key="SelectableCardStyle" TargetType="Grid">
                <Setter Property="Scale" Value="1" />
                <Setter Property="BackgroundColor" Value="{StaticResource M3Surface}" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="6" />
            </Style>
            
            <converter:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converter:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converter:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converter:BoolToFontAttributesConverter x:Key="BoolToFontAttributesConverter" />
            <converter:EqualsConverter x:Key="EqualsConverter" />
            <converter:AccountTypeToTextConverter x:Key="AccountTypeToTextConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
