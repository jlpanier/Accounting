<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    x:Class="Main.Templates.OverviewTemplate"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border 
        Margin="6,00" 
        Padding="12" 
        Background="AliceBlue"
        Stroke="DarkBlue"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 10">

        <Grid 
            ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto"  
            RowSpacing="1" ColumnSpacing="1">
            <Label Grid.Column="0" Grid.Row="0" Text="Dispobible" FontSize="14" FontAttributes="Bold" />
            <Label Grid.Column="0" Grid.Row="1" Text="Bloqué" FontSize="14" FontAttributes="Bold" />
            <Label Grid.Column="0" Grid.Row="2" Text="Retraite" FontSize="14" FontAttributes="Bold"/>

            <Label Grid.Column="1" Grid.Row="0" 
                   Text="{Binding Disponible, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="DarkGreen"
                   HorizontalTextAlignment="End"
                   VerticalTextAlignment="Center" />
            <Label Grid.Column="1" Grid.Row="1" 
                   Text="{Binding Block, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   TextColor="DarkGreen"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="End"
                   VerticalTextAlignment="Center" />
            <Label Grid.Column="1" Grid.Row="2" 
                   Text="{Binding Retirement, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   TextColor="DarkGreen"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="End"
                   VerticalTextAlignment="Center" />       
        </Grid>
    </Border>

</ContentView>