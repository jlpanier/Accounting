<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="Main.Templates.PeeTemplate"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border Margin="0,6" Padding="12" BackgroundColor="#E8F2FF" StrokeShape="RoundRectangle 24">
        <Border.GestureRecognizers>
            <TapGestureRecognizer 
                Command="{Binding SelectCommand}"
                CommandParameter="{Binding}" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">

            <Label Grid.Column="0" Grid.Row="0" Text="{Binding Label}" FontSize="18" FontAttributes="Bold" />
            <Label Grid.Column="0" Grid.Row="1" Text="{Binding AccountNo}" FontSize="14" />
            <Label Grid.Column="0" Grid.Row="2" Text="Disponible" FontSize="18" FontAttributes="Bold" />
            <Label Grid.Column="1" Grid.Row="2" 
                   Text="{Binding Disponible, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   TextColor="{Binding BalanceColor}"
                   HorizontalTextAlignment="End"
                   VerticalTextAlignment="Center" />

            <Label Grid.Column="0" Grid.Row="3" Text="Retraite" FontSize="18" FontAttributes="Bold" />
            <Label Grid.Column="1" Grid.Row="3" 
                   Text="{Binding Retirement, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   TextColor="{Binding BalanceColor}"
                   HorizontalTextAlignment="End"    
                   VerticalTextAlignment="Center" />

            <Label Grid.Column="0" Grid.Row="4" Text="Bloqué" FontSize="18" FontAttributes="Bold" />
            <Label Grid.Column="1" Grid.Row="4" 
                   Text="{Binding Blocked, StringFormat='{0:N2} €'}"
                   FontSize="14"
                   TextColor="{Binding BalanceColor}"
                   HorizontalTextAlignment="End"
                   VerticalTextAlignment="Center" />

        </Grid>
    </Border>

</ContentView>
